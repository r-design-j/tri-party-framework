{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tri-party model binding",
  "type": "object",
  "required": ["version", "cross_audit", "parties"],
  "properties": {
    "version": {
      "type": "string"
    },
    "cross_audit": {
      "type": "object",
      "required": ["required_for_true_tri_party", "default_pairs"],
      "properties": {
        "required_for_true_tri_party": {
          "type": "boolean",
          "const": true
        },
        "default_pairs": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "object",
            "required": ["reviewer", "target"],
            "properties": {
              "reviewer": {
                "type": "string",
                "enum": ["codex", "claude", "gemini"]
              },
              "target": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "parties": {
      "type": "object",
      "required": ["codex", "claude", "gemini"],
      "properties": {
        "codex": {
          "$ref": "#/$defs/party"
        },
        "claude": {
          "$ref": "#/$defs/party"
        },
        "gemini": {
          "allOf": [
            {
              "$ref": "#/$defs/party"
            },
            {
              "type": "object",
              "required": ["cli_model_name", "default_cli_args", "disabled_default_mcp_reason"]
            }
          ]
        }
      }
    }
  },
  "$defs": {
    "party": {
      "type": "object",
      "required": ["capability_role", "current_model", "primary_for"],
      "properties": {
        "capability_role": {
          "type": "string"
        },
        "current_model": {
          "type": "string"
        },
        "primary_for": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
