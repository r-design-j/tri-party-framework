{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tri-party run state",
  "type": "object",
  "required": [
    "schema_version",
    "core_version",
    "generated_at",
    "run_dir",
    "phase",
    "true_triparty_ready",
    "conclusion",
    "errors",
    "parties",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "triparty.state.v1"
    },
    "core_version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "runs_dir": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "phase": {
      "type": "string",
      "enum": [
        "created",
        "review_partial",
        "review_failed",
        "reviewed",
        "cross_audit_failed",
        "cross_audited",
        "merged_partial",
        "merged_ready"
      ]
    },
    "true_triparty_ready": {
      "type": "boolean"
    },
    "conclusion": {
      "type": "string"
    },
    "model_binding_sha256": {
      "type": "string"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "party", "code", "message"],
        "properties": {
          "stage": {
            "type": "string"
          },
          "party": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "parties": {
      "type": "object",
      "required": ["codex", "claude", "gemini"],
      "properties": {
        "codex": {
          "type": "object",
          "required": ["status", "role"]
        },
        "claude": {
          "$ref": "#/$defs/external_party_state"
        },
        "gemini": {
          "$ref": "#/$defs/gemini_party_state"
        }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["source_status", "cross_audit_status", "merge_status", "merge_input"]
    }
  },
  "$defs": {
    "external_party_state": {
      "type": "object",
      "required": [
        "preflight",
        "preflight_path",
        "preflight_version",
        "preflight_binary_sha256",
        "review",
        "review_error_code",
        "review_provenance",
        "review_provenance_detail",
        "review_sha256",
        "cross_audit",
        "cross_audit_error_code",
        "cross_audit_provenance",
        "cross_audit_provenance_detail",
        "cross_audit_sha256"
      ],
      "properties": {
        "preflight": {
          "type": "string"
        },
        "preflight_path": {
          "type": "string"
        },
        "preflight_version": {
          "type": "string"
        },
        "preflight_binary_sha256": {
          "type": "string"
        },
        "review": {
          "type": "string"
        },
        "review_error_code": {
          "type": "string"
        },
        "review_provenance": {
          "type": "string"
        },
        "review_provenance_detail": {
          "$ref": "#/$defs/provenance_detail"
        },
        "review_sha256": {
          "type": "string"
        },
        "cross_audit": {
          "type": "string"
        },
        "cross_audit_error_code": {
          "type": "string"
        },
        "cross_audit_provenance": {
          "type": "string"
        },
        "cross_audit_provenance_detail": {
          "$ref": "#/$defs/provenance_detail"
        },
        "cross_audit_sha256": {
          "type": "string"
        }
      }
    },
    "gemini_party_state": {
      "allOf": [
        {
          "$ref": "#/$defs/external_party_state"
        },
        {
          "type": "object",
          "required": ["preflight_policy_sha256", "review_diagnostics", "cross_audit_diagnostics"],
          "properties": {
            "preflight_policy_sha256": {
              "type": "string"
            },
            "auth_doctor": {
              "type": "object",
              "required": ["status", "output", "timeout_seconds", "exit_code"],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["authenticated", "interactive-auth-required", "binary-missing", "timeout", "unknown"]
                },
                "output": {
                  "type": "string"
                },
                "timeout_seconds": {
                  "type": "integer"
                },
                "exit_code": {
                  "type": "integer"
                }
              }
            },
            "review_diagnostics": {
              "$ref": "#/$defs/gemini_diagnostics"
            },
            "cross_audit_diagnostics": {
              "$ref": "#/$defs/gemini_diagnostics"
            }
          }
        }
      ]
    },
    "gemini_diagnostics": {
      "type": "object",
      "required": ["final_attempt", "capacity_events", "tool_block_events", "sanitized", "sanitizer_version"],
      "properties": {
        "final_attempt": {
          "type": "integer"
        },
        "capacity_events": {
          "type": "integer"
        },
        "tool_block_events": {
          "type": "integer"
        },
        "sanitized": {
          "type": "integer"
        },
        "sanitizer_version": {
          "type": "string"
        }
      }
    },
    "provenance_detail": {
      "type": "object",
      "required": ["origin", "injected_at", "source_path", "source_sha256", "artifact_sha256"],
      "properties": {
        "origin": {
          "type": "string",
          "enum": ["automated_cli", "user_supplied"]
        },
        "injected_at": {
          "type": ["string", "null"]
        },
        "source_path": {
          "type": ["string", "null"]
        },
        "source_sha256": {
          "type": ["string", "null"]
        },
        "artifact_sha256": {
          "type": "string"
        }
      }
    }
  }
}
